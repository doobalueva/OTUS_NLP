        "Следующая функция будет парсить уже контент со всех страниц и складывать информацию в словарик. Там будет:\n",
        "\n",
        "\n",
        "*   Название статьи\n",
        "*   Количество просмотров\n",
        "*   Текст статьи\n",
        "*   Длина текста в символах\n",
        "\n",
        "\n"
      ],
      "metadata": {
        "id": "5bitw1tij0_d"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def parse_article(url):\n",
        "    try:\n",
        "        response = requests.get(url, headers={'User-Agent': UserAgent().chrome}, timeout=10)\n",
        "        response.raise_for_status()\n",
        "        soup = BeautifulSoup(response.content, 'html.parser')\n",
        "\n",
        "        # Название\n",
        "        title = soup.find('h1').get_text(strip=True) if soup.find('h1') else 'Не найдено'\n",
        "\n",
        "        # Просмотры\n",
        "        views = 0\n",
        "        views_elem = soup.find('span', class_='tm-icon-counter__value')\n",
        "        if views_elem:\n",
        "            views_text = views_elem.get_text(strip=True)\n",
        "            views = re.sub(r'[^\\dK]', '', views_text) if re.sub(r'[^\\dK]', '', views_text) else 0\n",
        "            if views.endswith('K'):\n",
        "              views = float(re.sub(r'K', '', views_text))*1000\n",
        "            else:\n",
        "              views = int(views)\n",
        "\n",
        "        # Текст\n",
        "        text = ''\n",
        "        content = soup.find('div', id='post-content-body') or soup.find('div', class_='article-formatted-body')\n",
        "        if content:\n",
        "            # Удаляем ненужные элементы\n",
        "            for elem in content.find_all(['script', 'style', 'pre', 'code']):\n",
        "                elem.decompose()\n",
        "            text = content.get_text('\\n', strip=True)\n",
        "            text = re.sub(r'\\n\\s*\\n', '\\n\\n', text).strip()\n",
        "\n",
        "        return {\n",
        "            'title': title,\n",
        "            'views': views,\n",
        "            'text': text,\n",
        "            'text_len': len(text)\n",
        "        }\n",
        "\n",
        "    except Exception as e:\n",
        "        print(f\"Ошибка: {e}\")\n",
        "        return None"
      ],
      "metadata": {
